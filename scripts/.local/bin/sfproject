{
  "mcpServers": {
    "Salesforce DX": {
      "command": "npx",
      "args": [
        "-y", "@salesforce/mcp",
        "--orgs", "DEFAULT_TARGET_ORG,DEFAULT_TARGET_DEV_HUB",
        "--toolsets", "orgs,metadata,data,users,testing,code-analysis,lwc-experts",
        "--allow-non-ga-tools"
      ]
    }
  }
}
EOF

# ═══════════════════════════════════════════════════════════
#  scripts/hooks/
# ═══════════════════════════════════════════════════════════
cat > scripts/hooks/pre-apex-format.sh << 'HOOK'
#!/usr/bin/env bash
set -euo pipefail
if command -v prettier >/dev/null 2>&1; then
  npx prettier --plugin=prettier-plugin-apex --write "force-app/**/*.cls" "force-app/**/*.trigger" 2>/dev/null || true
else
  echo "⚠ prettier not found: npm install -D prettier prettier-plugin-apex"
fi
HOOK

cat > scripts/hooks/post-deploy-validate.sh << 'HOOK'
#!/usr/bin/env bash
set -euo pipefail
echo "Running post-deploy validation..."
if sf apex run test --test-level RunLocalTests --code-coverage --result-format human --wait 10; then
  echo "✓ All tests passed"
  notify-send -u normal "Salesforce" "Post-deploy validation passed" 2>/dev/null || true
else
  echo "✗ Tests failed"
  notify-send -u critical "Salesforce" "Post-deploy validation FAILED" 2>/dev/null || true
  exit 1
fi
HOOK

cat > scripts/hooks/lint-lwc.sh << 'HOOK'
#!/usr/bin/env bash
set -euo pipefail
if command -v eslint >/dev/null 2>&1; then
  npx eslint force-app/**/lwc/**/*.js --no-error-on-unmatched-pattern 2>/dev/null || true
else
  echo "⚠ eslint not found: npm install -D eslint @salesforce/eslint-config-lwc"
fi
HOOK

chmod +x scripts/hooks/*.sh

# ═══════════════════════════════════════════════════════════
#  scripts/automation/
# ═══════════════════════════════════════════════════════════
cat > scripts/automation/generate-test-data.sh << TESTDATA
#!/usr/bin/env bash
set -euo pipefail
outdir="force-app/main/default/classes"
mkdir -p "\$outdir"

cat > "\$outdir/TestDataFactory.cls" << 'APEX'
@isTest
public with sharing class TestDataFactory {

    public static Account createAccount(Map<String,Object> overrides) {
        Account a = new Account(Name = 'Test Account');
        if (overrides != null) {
            for (String field : overrides.keySet()) {
                a.put(field, overrides.get(field));
            }
        }
        insert a;
        return a;
    }

    public static List<Account> createAccounts(Integer count) {
        List<Account> accs = new List<Account>();
        for (Integer i = 0; i < count; i++) {
            accs.add(new Account(Name = 'Test Account ' + i));
        }
        insert accs;
        return accs;
    }

    public static Contact createContact(Account acct, Map<String,Object> overrides) {
        Contact c = new Contact(
            FirstName = 'Test',
            LastName = 'Contact',
            AccountId = acct.Id
        );
        if (overrides != null) {
            for (String field : overrides.keySet()) {
                c.put(field, overrides.get(field));
            }
        }
        insert c;
        return c;
    }
}
APEX

cat > "\$outdir/TestDataFactory.cls-meta.xml" << 'META'
<?xml version="1.0" encoding="UTF-8"?>
<ApexClass xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <status>Active</status>
</ApexClass>
META

echo "✓ TestDataFactory scaffolded to \$outdir/"
TESTDATA

cat > scripts/automation/scratch-org-setup.sh << SCRATCH
#!/usr/bin/env bash
set -euo pipefail
# Full scratch org bootstrap: create → push → assign permsets → load data

ALIAS="\${1:-${name}-scratch}"
DEVHUB="${devhub}"
DURATION="\${2:-7}"
DEF_FILE="config/project-scratch-def.json"

echo "Creating scratch org: \$ALIAS (duration: \$DURATION days)"

# Create scratch org
sf org create scratch \\
  --target-dev-hub "\$DEVHUB" \\
  --definition-file "\$DEF_FILE" \\
  --alias "\$ALIAS" \\
  --duration-days "\$DURATION" \\
  --set-default \\
  --wait 10

echo "✓ Scratch org created: \$ALIAS"

# Push source
echo "Deploying source..."
sf project deploy start --target-org "\$ALIAS"
echo "✓ Source deployed"

# Run tests
echo "Running tests..."
sf apex run test --test-level RunLocalTests --result-format human --wait 10 --target-org "\$ALIAS" || true

echo "✓ Scratch org \$ALIAS is ready"
echo "  Open: sf org open --target-org \$ALIAS"
notify-send "Salesforce" "Scratch org \$ALIAS ready ✓" 2>/dev/null || true
SCRATCH

chmod +x scripts/automation/*.sh

