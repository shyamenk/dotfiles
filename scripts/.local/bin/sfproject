cat > .claude/skills/appexchange-research/scripts/scrape_appexchange.sh << 'SCRAPER'
#!/usr/bin/env bash
set -euo pipefail
# Scrape AppExchange listings via public search
# Usage: scrape_appexchange.sh "search term" [max_results]

query="${1:?Usage: scrape_appexchange.sh \"search term\" [max_results]}"
max="${2:-10}"
encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$query'))" 2>/dev/null || echo "$query")

echo "Searching AppExchange for: $query (max: $max)"

# Fetch search results page
url="https://appexchange.salesforce.com/appxSearchKeywordResults?keywords=${encoded}"
html=$(curl -sL "$url" --max-time 15 || { echo "Failed to fetch AppExchange"; exit 1; })

# Extract listing URLs from search results
echo "$html" | grep -oP 'href="/appxListingDetail\?listingId=[^"]+' | \
  head -n "$max" | \
  sed 's|^href="||' | \
  while read -r path; do
    listing_url="https://appexchange.salesforce.com${path}"
    listing_html=$(curl -sL "$listing_url" --max-time 10 2>/dev/null || continue)
    title=$(echo "$listing_html" | grep -oP '<title>[^<]+' | sed 's/<title>//' | head -1)
    echo "  → $title"
    echo "    URL: $listing_url"
  done

echo ""
echo "Done. For deeper analysis, use Apify: jungle_synthesizer/salesforce-appexchange-scraper"
SCRAPER
chmod +x .claude/skills/appexchange-research/scripts/scrape_appexchange.sh

