#!/usr/bin/env bash
set -euo pipefail

# ╔══════════════════════════════════════════════════════════╗
# ║  sfproject — Salesforce 2GP Project Scaffolder           ║
# ║  Creates SFDX project + .claude/ intelligence layer      ║
# ╚══════════════════════════════════════════════════════════╝

# ─── Prompts ───────────────────────────────────────────────
read -rp "Project name: " name
[[ -z "$name" ]] && { echo "Name required."; exit 1; }

read -rp "Namespace (empty for none): " namespace
namespace="${namespace:-}"

read -rp "Dev Hub [amd-dev-hub]: " devhub
devhub="${devhub:-amd-dev-hub}"

template=$(printf "standard\n2gp-managed\nunlocked-package" | \
  fzf --prompt="Template> " --height=40% --reverse)
[[ -z "$template" ]] && exit 0

echo ""
echo "  Project:   $name"
echo "  Namespace: ${namespace:-<none>}"
echo "  Dev Hub:   $devhub"
echo "  Template:  $template"
echo ""
read -rp "Create project? [Y/n]: " confirm
[[ "${confirm:-Y}" =~ ^[Nn] ]] && { echo "Aborted."; exit 0; }

# ─── Generate SFDX project ────────────────────────────────
sf project generate -n "$name" --template standard
cd "$name"

# Inject namespace into sfdx-project.json if provided
if [[ -n "$namespace" ]]; then
  tmp=$(mktemp)
  jq --arg ns "$namespace" '.namespace = $ns' sfdx-project.json > "$tmp" && mv "$tmp" sfdx-project.json
fi

# ─── Directory structure ──────────────────────────────────
mkdir -p .claude/{memory,rules}
mkdir -p .claude/skills/{create-2gp-version,run-apex-tests,deploy-validate,generate-test-factory,metadata-audit,architect,appexchange-research/scripts}
mkdir -p .claude/agents
mkdir -p scripts/{hooks,automation}

# ═══════════════════════════════════════════════════════════
#  .claude/CLAUDE.md
# ═══════════════════════════════════════════════════════════
cat > .claude/CLAUDE.md << EOF
# CLAUDE — Project Brain

## Project
- type: salesforce-2gp
- name: ${name}
- namespace: ${namespace:-<not-set>}
- devhub: ${devhub}
- cli: sf (Salesforce unified CLI only — never use sfdx)

## Workflow
- default-mode: interactive
- plan-mode: required for multi-file edits
- edit-mode: safe-write (confirm large writes)

## Token Discipline
- max-inline-metadata-lines: 40
- compaction-interval-steps: 4
- research-agent: allowed to call MCP endpoints and web-search only

## Agent Workflow (Design & Build Loop)
1. Write/edit code
2. Spawn code-review-agent → returns issues (read-only, no fixes)
3. Spawn qa-agent → generates tests, runs them (read-only, no fixes)
4. Parent agent reads reports and applies all fixes
5. Ship only after review passes and tests pass

Subagents are read-only reporters. All code changes happen in the parent agent.

## Self-Annealing Loop
When something breaks: fix → test → update SKILL.md with learnings → system is stronger.

## References
- rules/: coding and security standards
- skills/: executable checklists (SKILL.md + scripts/)
- agents/: sub-agent configurations (read-only reporters)
- memory/: small persistent facts only (never secrets)
EOF

# ═══════════════════════════════════════════════════════════
